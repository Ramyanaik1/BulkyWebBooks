@using BulkyWeb.Utilities
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BulkyWebBooks</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link rel="stylesheet" href="~/BulkyBookWeb.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/css/toastr.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="//cdn.datatables.net/1.13.3/css/jquery.dataTables.min.css" />
    <link rel="stylesheet" href="//cdn.datatables.net/2.3.7/css/dataTables.dataTables.min.css" />

    <style>
        /* Gentle hover effect */
        .nav-link {
            transition: color 0.2s ease, background-color 0.2s ease;
            border-radius: 5px;
        }

            .nav-link:hover {
                color: #0d6efd; /* Bootstrap primary blue */
                background-color: #f8f9fa;
            }

        .navbar-brand {
            font-weight: 600;
            color: #0d6efd !important;
        }

        .dropdown-menu {
            border-radius: 8px;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-light border-bottom shadow-sm mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">BulkyWebBooks</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarNav" aria-controls="navbarNav"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-secondary" asp-area="Admin" asp-controller="Home" asp-action="Books">Home</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-secondary" asp-area="Admin" asp-controller="Order" asp-action="Index">Orders</a>
                            </li>

                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-secondary" asp-area="Admin" asp-controller="Company" asp-action="Index">Company</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-secondary" asp-area="Admin" asp-controller="User" asp-action="Index">Manage Users</a>
                                </li>
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-secondary" href="#" role="button" data-bs-toggle="dropdown">
                                        Content Management
                                    </a>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item" asp-area="Customer" asp-controller="Categories" asp-action="Index">Category</a></li>
                                        <li><a class="dropdown-item" asp-area="Customer" asp-controller="Product" asp-action="Index">Product</a></li>
                                    </ul>
                                </li>
                            }

                            <li class="nav-item">
                                <a class="nav-link text-secondary" asp-area="Customer" asp-controller="Cart" asp-action="Index">
                                    Cart @await Component.InvokeAsync("ShoppingCart")
                                </a>
                            </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            <i class="bi bi-heart-fill"></i>
            &copy; 2026 - BulkyWebBooks -
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="//cdn.datatables.net/2.3.7/js/dataTables.min.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>