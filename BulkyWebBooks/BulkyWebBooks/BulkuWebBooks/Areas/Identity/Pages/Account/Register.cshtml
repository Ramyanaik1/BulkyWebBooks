@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <!-- Registration Card -->
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-5 bg-light">
                    <h1 class="card-title text-center mb-4 text-primary fw-bold">
                        <i class="bi bi-person-plus-fill me-2"></i>@ViewData["Title"]
                    </h1>

                    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        <h5 class="mb-4 text-muted text-center">Create a new account</h5>
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3" role="alert"></div>

                        <!-- Email -->
                        <div class="form-floating mb-3 position-relative">
                            <input asp-for="Input.Name"
                                   class="form-control rounded-3 ps-5"
                                   autocomplete="username"
                                   aria-required="true"
                                   placeholder="name@example.com" />
                            <label asp-for="Input.Name"></label>
                            <i class="bi bi-person-fill position-absolute top-50 start-0 translate-middle-y ms-3 text-secondary"></i>
                        </div>
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control rounded-3" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <label asp-for="Input.Email"><i class="bi bi-envelope-fill me-2"></i>Email</label>
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>
                        <!-- Passwords Row -->
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Input.Password" type="password" class="form-control rounded-3" autocomplete="new-password" aria-required="true" placeholder="password" />
                                    <label asp-for="Input.Password"><i class="bi bi-lock-fill me-2"></i>Password</label>
                                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Input.ConfirmPassword" type="password" class="form-control rounded-3" autocomplete="new-password" aria-required="true" placeholder="password" />
                                    <label asp-for="Input.ConfirmPassword"><i class="bi bi-shield-lock-fill me-2"></i>Confirm</label>
                                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Role -->
                        <div class="form-floating mb-3">
                            <select asp-for="Input.Role" asp-items="@Model.Input.RoleList" class="form-select rounded-3">
                                <option value="">-- Select Role --</option>
                            </select>
                            <label asp-for="Input.Role"><i class="bi bi-people-fill me-2"></i>Role</label>
                        </div>

                        <!-- Company (collapsible) -->
                        <div id="companyWrapper" class="collapse fade">
                            <div class="form-floating mb-3">
                                <select asp-for="Input.CompanyId" asp-items="@Model.Input.CompanyList" class="form-select rounded-3">
                                    <option value="">-- Select Company --</option>
                                </select>
                                <label asp-for="Input.CompanyId"><i class="bi bi-buildings-fill me-2"></i>Company</label>
                            </div>
                        </div>

                        <!-- Address Row -->
                        <div class="form-floating mb-3">
                            <input asp-for="Input.StreetAddress" class="form-control rounded-3" placeholder="123 Main St" />
                            <label asp-for="Input.StreetAddress"><i class="bi bi-house-door-fill me-2"></i>Street Address</label>
                            <span asp-validation-for="Input.StreetAddress" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Input.City" class="form-control rounded-3" placeholder="City" />
                                    <label asp-for="Input.City"><i class="bi bi-building-fill me-2"></i>City</label>
                                    <span asp-validation-for="Input.City" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Input.State" class="form-control rounded-3" placeholder="State" />
                                    <label asp-for="Input.State"><i class="bi bi-geo-alt-fill me-2"></i>State</label>
                                    <span asp-validation-for="Input.State" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Input.PostalCode" class="form-control rounded-3" placeholder="Postal Code" />
                                    <label asp-for="Input.PostalCode"><i class="bi bi-mailbox2 me-2"></i>Postal Code</label>
                                    <span asp-validation-for="Input.PostalCode" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Input.PhoneNumber" class="form-control rounded-3" placeholder="Phone Number" />
                                    <label asp-for="Input.PhoneNumber"><i class="bi bi-telephone-fill me-2"></i>Phone</label>
                                    <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Submit Button -->
                        <button id="registerSubmit" type="submit" class="btn btn-primary w-100 btn-lg shadow-sm rounded-3">
                            <i class="bi bi-check-circle-fill me-2"></i>Register
                        </button>
                    </form>
                </div>
            </div>

            <!-- External Login Card -->
            <div class="card mt-4 shadow-lg border-0 rounded-4">
                <div class="card-body text-center bg-light">
                    <h5 class="card-title mb-3 text-secondary">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Use another service to register
                    </h5>
                    <hr />
                    @if ((Model.ExternalLogins?.Count ?? 0) == 0)
                    {
                        <div class="alert alert-info rounded-3">
                            <p>
                                No external authentication services configured. See this
                                <a href="https://go.microsoft.com/fwlink/?LinkID=532715" target="_blank">article</a>
                                to set up external logins.
                            </p>
                        </div>
                    }
                    else
                    {
                        <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                            @foreach (var provider in Model.ExternalLogins!)
                            {
                                <button type="submit" class="btn btn-outline-primary me-2 mb-2 shadow-sm rounded-3" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account">
                                    <i class="bi bi-box-arrow-in-right me-1"></i>@provider.DisplayName
                                </button>
                            }
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            var companyCollapse = new bootstrap.Collapse($('#companyWrapper')[0], { toggle: false });

            $('#Input_Role').on('change', function () {
                var selectedRole = $(this).val();
                if (selectedRole === 'Company') {
                    companyCollapse.show();
                } else {
                    companyCollapse.hide();
                    $('#Input_CompanyId').val('');
                }
            }).trigger('change'); // initialize on page load
        });
    </script>
}