@using BulkyWeb.Models.Models.ViewModels
@model ShoppingCartVM

@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="container py-5">
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4">
            <h2 class="fw-bold text-primary mb-4">
                <i class="bi bi-cart-check"></i> Your Shopping Cart
            </h2>

            @if (Model.ShoppingCartList != null && Model.ShoppingCartList.Any())
            {
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 120px;">Product</th>
                                <th>Details</th>
                                <th class="text-center">Quantity</th>
                                <th class="text-end">Subtotal</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.ShoppingCartList)
                            {
                                <tr>
                                    <td>
                                        @* <img src="@item.Product.ImageUrl" alt="@item.Product.Title" *@
                                             class="img-fluid rounded shadow-sm" style="max-height: 100px;" />
                                    </td>
                                    <td>
                                        <div class="fw-semibold">@item.Product.Title</div>
                                        <div class="text-muted">Price: @item.Product.Price.ToString("C")</div>
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group" role="group">
                                            <a asp-action="plus" asp-route-cartId="@item.ShoppingCartId"
                                               class="btn btn-outline-primary bg-gradient py-1 px-2">
                                                <i class="bi bi-plus-square"></i>
                                            </a>
                                            <span class="mx-2 fw-bold">@item.Count</span>
                                            <a asp-action="minus" asp-route-cartId="@item.ShoppingCartId"
                                               class="btn btn-outline-primary bg-gradient py-1 px-2">
                                                <i class="bi bi-dash-square"></i>
                                            </a>
                                        </div>
                                    </td>
                                    <td class="fw-bold text-success text-end">
                                        @((item.Product.Price * item.Count).ToString("C"))
                                    </td>
                                    <td class="text-center">
                                        <form asp-action="Remove" method="post" class="d-inline">
                                            <input type="hidden" name="cartId" value="@item.ShoppingCartId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                                <i class="bi bi-trash"></i> Remove
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-end mt-4">
                    <div class="text-end">
                        <h4 class="fw-bold">
                            Total: <span class="text-primary">@Model.OrderHeader.OrderTotal.ToString("C")</span>
                        </h4>
                        <form asp-action="Checkout" method="post" class="d-inline">
                            <button type="submit" class="btn btn-lg btn-primary rounded-pill shadow-sm px-4 mt-3">
                                <i class="bi bi-credit-card"></i> Proceed to Checkout
                            </button>
                        </form>

                        <!-- Order Summary Button -->
                        <form asp-action="Summary" method="get" class="d-inline">
                            <button type="submit" class="btn btn-lg btn-outline-secondary rounded-pill shadow-sm px-4 mt-3 ms-2">
                                <i class="bi bi-list-check"></i> View Order Summary
                            </button>
                        </form>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-info rounded-3 shadow-sm">
                    <i class="bi bi-info-circle"></i> Your cart is empty. Start adding some products!
                </div>
            }
        </div>
    </div>
</div>