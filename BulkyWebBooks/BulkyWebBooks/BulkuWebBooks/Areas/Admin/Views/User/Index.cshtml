@model IEnumerable<BulkyWeb.Models.Models.ApplicationUser>

@{
    ViewData["Title"] = "Application Users";
}

<div class="container mt-4">
    <h2 class="mb-3">@ViewData["Title"]</h2>

    <table class="table table-hover table-bordered align-middle">
        <thead class="table-dark">
            <tr>
                <th>@Html.DisplayNameFor(m => m.First().Name)</th>
                <th>@Html.DisplayNameFor(m => m.First().Email)</th>
                <th>@Html.DisplayNameFor(m => m.First().PhoneNumber)</th>
                <th>@Html.DisplayNameFor(m => m.First().Company.Name)</th>
                <th>@Html.DisplayNameFor(m => m.First().Role)</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Name</td>
                    <td>@user.Email</td>
                    <td>@user.PhoneNumber</td>
                    <td>@user.Company?.Name</td>
                    <td>@user.Role</td>
                    <td class="text-center">
                        <a asp-action="RoleManagment" asp-route-id="@user.Id" class="btn btn-sm btn-primary me-2">
                            <i class="bi bi-pencil-square"></i> Details
                        </a>
                        <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-sm btn-danger">
                            <i class="bi bi-trash"></i> Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @* <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Add New User
    </a> *@
</div>