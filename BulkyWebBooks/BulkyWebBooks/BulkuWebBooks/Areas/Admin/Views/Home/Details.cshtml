@model ShoppingCart

<div class="container py-5">
    <form asp-action="Details" method="post" class="shadow-sm p-4 rounded bg-light">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ProductId" />
        <input type="hidden" asp-for="ShoppingCartId" />
        <div class="row g-4 align-items-start">
            <!-- Book Image -->
            <div class="col-lg-5 col-md-6 text-center">
                @if (Model.Product.ProductImages != null && Model.Product.ProductImages.Count > 0)
                {
                    <div id="carouselExampleIndicators" class="carousel  slide" data-bs-ride="carousel">
                        <div class="carousel-indicators">

                            @foreach (var imageWithIndex in
                                                    Model.Product.ProductImages
                                                    .Select((image, index) => new { Image = image, Index = index }))
                            {
                                <button type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide-to="@imageWithIndex.Index"
                                        class="@(imageWithIndex.Index == 0 ? "active" : "")" aria-current="true" aria-label="Slide 1"></button>
                            }


                        </div>
                        <div class="carousel-inner">
                            @foreach (var imageWithIndex in
                                                    Model.Product.ProductImages
                                                    .Select((image, index) => new { Image = image, Index = index }))
                            {
                                <div class="@(imageWithIndex.Index == 0 ? "carousel-item active" : "carousel-item")">
                                    <img src="@imageWithIndex.Image.ImageUrl" class="d-block w-100" alt="...">
                                </div>
                            }
                        </div>
                        <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Previous</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Next</span>
                        </button>
                    </div>

                }

            </div>

            <!-- Book Details -->
            <div class="col-lg-7 col-md-6">
                <h2 class="fw-bold text-primary text-uppercase mb-2">@Model.Product.Title</h2>
                <h5 class="text-muted mb-3">
                    by <span class="text-warning fw-semibold">@Model.Product.Author</span>
                </h5>

                <!-- Pricing -->
                <div class="mb-3">
                    <span class="badge bg-danger fs-6 rounded-pill">List Price: @Model.Product.ListPrice.ToString("c")</span>
                </div>
                <div class="mb-2">
                    <span class="badge bg-success fs-6 rounded-pill">Price (1–50): @Model.Product.Price.ToString("c")</span>
                </div>
                <div class="mb-2">
                    <span class="badge bg-info text-dark fs-6 rounded-pill">Price (50+): @Model.Product.Price50.ToString("c")</span>
                </div>
                <div class="mb-2">
                    <span class="badge bg-primary fs-6 rounded-pill">Price (100+): @Model.Product.Price100.ToString("c")</span>
                </div>

                <!-- Category -->
                <div class="mb-3">
                    <span class="badge bg-secondary fs-6 rounded-pill">Category: @Model.Product.Category?.CategoryName</span>
                </div>

                <!-- Description -->
                <p class="lead text-dark opacity-75 mt-4">
                    @Model.Product.Description
                </p>

                <!-- Quantity Selector -->
                <div class="mt-3">
                    <div class="col-md-6">
                        <div class="input-group mb-3 shadow-sm rounded">
                            <span class="input-group-text bg-primary text-white fw-semibold rounded-start">
                                Count
                            </span>
                            <input asp-for="Count" type="number" min="1" max="1000" class="form-control text-end rounded-end" value="1" />
                        </div>
                        <span asp-validation-for="Count" class="text-danger small"></span>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="mt-4">
                    <button type="submit" class="btn btn-primary btn-lg shadow-sm rounded-pill px-4">
                        🛒 Add to Cart
                    </button>
                </div>
            </div>
        </div>
    </form>

    <!-- Success Alert (TempData) -->
    @if (TempData["success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm rounded-pill mt-4">
            <strong>🎉 Great choice!</strong> @TempData["success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}